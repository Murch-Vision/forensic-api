# Copy this file to ".env" and edit it.

# Port the GraphQL API listens on.
PORT=4000

# Browser origins allowed to call this API, comma-separated. Unset reflects
# whichever origin asks, which is what an on-premise install wants: the same
# machine is reached by localhost, by hostname and by LAN IP.
# CORS_ORIGIN=http://localhost:5173,http://192.168.1.50:5173

# Max request body. Imported statements arrive base64-encoded in the mutation
# body, so the default is 50mb.
# BODY_LIMIT=50mb

# Database. SQLite unless DB_CLIENT=pg.
# DATA_DIR=C:\Murch\data
# DB_FILE=C:\Murch\data\forensic.sqlite
# DB_CLIENT=pg

# Location printed in the PDF report header.
# REPORT_LOCATION=Улаанбаатар хот
